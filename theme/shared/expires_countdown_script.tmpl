{{ define "expires_countdown" }}
  {{ if .ExpiresAt }}
    <style nonce="{{ .Nonce }}">
      .expires-countdown {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 12px;
        width: 100%;
      }
      .expires-progress-track {
        width: 240px;
        height: 4px;
        background: rgba(0, 126, 255, 0.24);
        border-radius: 2px;
        overflow: hidden;
      }
      .expires-progress-fill {
        height: 100%;
        width: 100%;
        background: #007EFF;
        border-radius: 2px;
        transition: width 1s linear;
      }
      .expires-countdown.expiring .expires-progress-fill {
        background: #CF3228;
      }
      .expires-text {
        display: flex;
        align-items: center;
        gap: 4px;
        font-size: 12px;
        line-height: 16px;
        color: #9EA1B7;
      }
      .expires-label {
        font-weight: 400;
      }
      .expires-time {
        font-weight: 600;
        font-variant-numeric: tabular-nums;
      }
      .expires-countdown.expiring .expires-time {
        color: #CF3228;
      }
      .expires-countdown.expired .expires-text {
        color: #CF3228;
        font-weight: 600;
      }
    </style>
    <div class="expires-countdown" id="expires-countdown" data-expires="{{ .ExpiresAt }}" role="timer" aria-live="polite" aria-atomic="true">
      <div class="expires-progress-track" role="progressbar" aria-valuemin="0" aria-valuemax="100" aria-valuenow="100">
        <div class="expires-progress-fill" id="expires-progress-fill"></div>
      </div>
      <div class="expires-text">
        <span class="expires-label" id="expires-label">{{ T "identity.login.authn_mode_push.expires_in" }}</span>
        <span class="expires-time" id="expires-time"></span>
      </div>
    </div>
    <script nonce="{{ .Nonce }}">
      (function() {
        var container = document.getElementById('expires-countdown');
        if (!container) return;

        var expiresAt = new Date(container.getAttribute('data-expires'));
        var fillEl = document.getElementById('expires-progress-fill');
        var timeEl = document.getElementById('expires-time');
        var labelEl = document.getElementById('expires-label');
        var expiredText = "{{ T "identity.login.authn_mode_push.request_expired" }}";
        var submitted = false;

        if (isNaN(expiresAt.getTime())) return;

        var now = new Date();
        var totalMs = expiresAt.getTime() - now.getTime();
        if (totalMs <= 0) totalMs = 0;

        function update() {
          var remainingMs = expiresAt.getTime() - new Date().getTime();
          if (remainingMs <= 0) remainingMs = 0;

          var totalSeconds = Math.ceil(remainingMs / 1000);

          if (remainingMs <= 0) {
            container.classList.remove('expiring');
            container.classList.add('expired');
            fillEl.style.width = '0%';
            labelEl.style.display = 'none';
            timeEl.textContent = expiredText;

            var lottie = document.querySelector('lottie-player');
            if (lottie && typeof lottie.stop === 'function') {
              lottie.stop();
            }

            clearInterval(intervalId);

            if (!submitted) {
              submitted = true;
              setTimeout(function() {
                var form = container.closest('form');
                if (form) {
                  var input = document.createElement('input');
                  input.type = 'hidden';
                  input.name = 'action';
                  input.value = 'submit';
                  form.appendChild(input);
                  form.submit();
                }
              }, 1000);
            }

            return;
          }

          if (totalSeconds <= 20) {
            container.classList.add('expiring');
          }

          var minutes = Math.floor(totalSeconds / 60);
          var seconds = totalSeconds % 60;
          timeEl.textContent = minutes + ':' + (seconds < 10 ? '0' : '') + seconds;

          var pct = totalMs > 0 ? (remainingMs / totalMs) * 100 : 0;
          fillEl.style.width = pct + '%';
        }

        update();
        var intervalId = setInterval(update, 1000);

        document.addEventListener('visibilitychange', function() {
          if (submitted) return;
          if (document.hidden) {
            clearInterval(intervalId);
          } else {
            update();
            intervalId = setInterval(update, 1000);
          }
        });
      })();
    </script>
  {{ end }}
{{ end }}
