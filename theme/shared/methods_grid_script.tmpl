{{ define "methods_grid_script" }}
  <script nonce="{{ .Nonce }}">
    function initMethodsGrid(gridId) {
      var grid = document.getElementById(gridId);
      if (!grid) return;
      var items = grid.querySelectorAll('.href-card');
      var count = items.length;
      var gap = 8;

      // Calculate items per row based on count
      // - 1-3 items: single row
      // - 4 items: [2, 2]
      // - 5 items: [3, 2]
      // - 6 items: [3, 3]
      // - 7 items: [3, 3, 1]
      // - 8 items: [3, 3, 2]
      // - 9+ items: rows of 3, remainder in last row
      var rowCounts = [];
      if (count === 1) {
        rowCounts = [1];
      } else if (count === 2) {
        rowCounts = [2];
      } else if (count === 3) {
        rowCounts = [3];
      } else if (count === 4) {
        rowCounts = [2, 2];
      } else if (count === 5) {
        rowCounts = [3, 2];
      } else if (count === 6) {
        rowCounts = [3, 3];
      } else {
        // 7+ items: rows of 3, last row gets remainder
        var fullRows = Math.floor(count / 3);
        var remainder = count % 3;
        for (var r = 0; r < fullRows; r++) {
          rowCounts.push(3);
        }
        if (remainder > 0) {
          rowCounts.push(remainder);
        }
      }

      // Apply flex-basis to each item
      var itemIndex = 0;
      for (var row = 0; row < rowCounts.length; row++) {
        var itemsInRow = rowCounts[row];
        for (var col = 0; col < itemsInRow; col++) {
          if (itemIndex < items.length) {
            items[itemIndex].style.marginBottom = '0';
            items[itemIndex].style.flex = '1 1 calc(' + (100 / itemsInRow) + '% - ' + gap + 'px)';
            items[itemIndex].style.maxWidth = 'calc(' + (100 / itemsInRow) + '% - ' + (gap * (itemsInRow - 1) / itemsInRow) + 'px)';
            itemIndex++;
          }
        }
      }
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', function() { initMethodsGrid('{{ .GridId }}'); });
    } else {
      initMethodsGrid('{{ .GridId }}');
    }
  </script>
{{ end }}
