{{ define "demo-id-token-tab" }}

 <div id="id-token" class="content non-visible">
  <h3>{{ T "authorization.demo.demo-id-token-tab.header" }}</h3>
  <pre>{{ .Data.IDTokenHeader }}</pre>

  <h3>{{ T "authorization.demo.demo-id-token-tab.payload" }}</h3>
  <pre>{{ .Data.IDTokenPayload }}</pre>

  <h3>{{ T "authorization.demo.demo-id-token-tab.raw" }}</h3>
  <pre class="with-copy">
    <div class="pre-copy-button" data-copy-value="{{ .Data.IDTokenRaw }}">
      <i class="material-icons">content_copy</i>
      <span>{{ T "authorization.demo.demo-id-token-tab.copy_code" }}</span>
    </div>
    {{ .Data.IDTokenRaw }}
  </pre>
</div>

{{ end }}
