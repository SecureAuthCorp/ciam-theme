{{ define "demo-refresh-token-tab" }}

<div id="refresh-token" class="content non-visible">
  <h3>{{ T "authorization.demo.demo-refresh-token-tab.raw" }}</h3>
  <pre class="with-copy">
    <div class="pre-copy-button" data-copy-value="{{ .Data.RefreshTokenRaw }}">
      <i class="material-icons">content_copy</i>
      <span>{{ T "authorization.demo.demo-refresh-token-tab.copy_code" }}</span>
    </div>
    {{ .Data.RefreshTokenRaw }}
  </pre>
</div>

{{ end }}
