{{ template "base" . }}

{{ define "title" }}{{ T "authorization.select-account.title" }}{{ end }}

{{ define "content" }}

  <div class="header-container">
    {{ template "header" .Config }}
  </div>

  <div class="card">
    <div class="content" id="main-content">

      <h1 class="margin-bottom-16">{{ T "authorization.select-account.title" }}</h1>

      <div class="header-info">{{ T "authorization.select-account.to_continue_to" }} <b>{{ .Data.AppName }}</b></div>

      <a class="choose-account-card-link" href="{{ .Data.SelectOriginalAccountURL }}">
        <div class="login-welcome-back-card">
          <img src="{{ .Config.Assets }}/static/images/person-icon.svg" alt="welcome back image"/>
          <div>
            <div class="login-welcome-back-card-name">
              {{ or .Data.SSOSession.AuthenticationContext.name .Data.SSOSession.Subject }}
            </div>
            <div class="login-welcome-back-card-email">
              {{ or .Data.SSOSession.AuthenticationContext.email .Data.SSOSession.Subject }}
            </div>
          </div>
        </div>
      </a>

      <a href="{{ .Data.SelectDifferentAccountURL }}" class="login-welcome-back-select-different-link no-bottom-margin">
        {{ T "authorization.select-account.sign_in_with_different_account" }}
      </a>
    </div>
  </div>

  {{ template "footer" . }}
{{ end }}
