{{ template "base" . }}

{{ define "title" }}SAML Test{{ end }}

{{ define "content" }}

  <div class="header-container">
    {{ template "header" .Config }}
  </div>

  <div class="card" {{ if .Data.Response }} style="max-width: 90%" {{ end }}>
    <h3 class="header">SAML Test</h3>

    <div class="content" id="saml-response-raw">
      {{ if .Data.Response  }}
        <pre>{{ .Data.Response }}</pre>
      {{ else }}
        <form action="?action=login" method="post">
          <button class="submit-button" type="submit" id="sign-in">Login</button>
          <div class="form-field">
            <label>Subject Name ID</label>
            <input name="subject-name-id">
          </div>
        </form>
      {{ end }}
    </div>
  </div>

  {{ template "footer" . }}

{{ end }}%