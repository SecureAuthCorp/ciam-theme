{{ define "authn_otp_verify" }}

<div class="reverse-flex-container">
    <div>
        <input id="original-identifier-input" type="hidden" name="destination_address" value="{{ .Data.ResolvedDestinationAddress }}">
        <input type="checkbox" name="{{ if eq .Data.OtpMode ""}}otpMode{{ else if eq .Data.OtpMode "sms" }}smsOtpMode{{ else }}emailOtpMode{{ end }}" id="otpMode" checked class="non-visible">

        <div class="log-in-header-container">
            <h2 id="log-in-header">Verify code</h2>
            {{ if .Data.Is2FAStep }}
                <img src="{{ .Config.Assets }}/static/images/2fa-icon.svg" alt="second factor step" class="icon-2fa"/>
            {{ end }}
        </div>

        {{ if .Data.IsForceAuthMode}}
            <div class="login-welcome-back-card">
                <img src="{{ .Config.Assets }}/static/images/person-icon.svg" alt="person icon"/>
                <div>
                <div class="login-welcome-back-card-name">
                    {{ .Data.UserDisplayName }}
                </div>
                </div>
            </div>
        {{ else }}
        <div class="form-field">
            <label for="text-field-username-input" class="label-with-link">
                <span id="username-label">User Identifier</span>
                {{ if not .Data.Is2FAStep }}
                    <button id="not-you-button" type="submit" name="action" value="change_to_{{ if (not (eq .Data.OtpMode "" ))}}{{ .Data.OtpMode }}_{{ end }}otp">Change</button>
                {{ end }}
            </label>
            <input id="text-field-username-input" name="identifier" value="{{ .Data.Identifier }}" disabled>
        </div>
        {{ end }}

        <div class="form-field" id="otp-container">
            <div id="otp-input-container" class="form-field otp-input-container">
                <input type="hidden" name="otp" value="" id="otp-input">
            </div>
            {{ if or (eq .Data.UserID "") (gt .Data.NumberOfAddresses 0) }}
                <div class="footer-with-link">
                    Still didn't receive?
                    <button id="resend-otp" type="submit" name="action" value="send_{{ if (not (eq .Data.OtpMode "" ))}}{{ .Data.OtpMode }}_{{ end }}otp">Resend Code</button>
                </div>
            {{ end }}
        </div>

        {{ template "reduce_mfa_prompts" . }}

        {{ if and (or .Data.Is2FAStep .Data.IsForceAuthMode) .Data.AuthnModeSwitch }}
            <div class="buttons-container-full-width flex-row-reverse extra-bottom-margin">
                <button class="contained-button" type="submit" id="verify-button">Continue</button>
                <button class="text-button" type="submit" name="action" value="change_to_{{ if (not (eq .Data.OtpMode "" ))}}{{ .Data.OtpMode }}_{{ end }}otp">Back</button>
            </div>
        {{ else }}
            <button class="submit-button" type="submit" id="verify-button">Continue</button>
        {{ end }}

        {{ if .Data.AuthnModeSwitch }}
            {{ template "authn_methods" . }}
        {{ end }}

        <input type="hidden" name="authn_mode" value="otp_send_view" id="authnView-input">
    </div>

    <div class="notification-container" id="code-sent-notification">
        {{ if eq (len .Data.FormError.Errors) 0 }}
            {{ if and (ne .Data.UserID "") (not .Data.OtpSent) }}
                <span>Code not sent{{ if eq .Data.NumberOfAddresses 0 }}. No addresses defined
                    {{ else if and (eq .Data.OtpMode "email") (eq (len .Data.UserEmails) 0)}}. No emails defined
                    {{ else if and (eq .Data.OtpMode "sms") (eq (len .Data.UserMobiles) 0)}}. No mobiles defined
                    {{ end }}
                </span>
            {{ else }}
                <i class="material-icons">send</i>
                <span>We sent a code to {{ .Data.BlurredResolvedDestinationAddress }}</span>
            {{ end }}
        {{ else }}
            <span></span>
        {{ end }}

        {{ if or
            (and (eq .Data.OtpMode "") (or (eq .Data.UserID "") (gt .Data.NumberOfAddresses 1)))
            (and (eq .Data.OtpMode "email") (or (eq .Data.UserID "") (gt (len .Data.UserEmails) 1)))
            (and (eq .Data.OtpMode "sms") (or (eq .Data.UserID "") (gt (len .Data.UserMobiles) 1)))
        }}
            <button id="use-alternative-address-button" type="submit" name="action" value="change_to_{{ if (not (eq .Data.OtpMode "" ))}}{{ .Data.OtpMode }}_{{ end }}otp_use_alternative">Use Alternative</button>
        {{ end }}
    </div>
</div>

{{ end }}
