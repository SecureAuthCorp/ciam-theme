{{ define "authn_otp_send" }}

  <div class="log-in-header-container">
      <h1 id="log-in-header">{{ if .Data.IsForceAuthMode}}{{ T "identity.login.authn_mode_otp_send.confirm" }}{{ else }}{{ T "identity.login.authn_mode_otp_send.log_in" }}{{ end }} {{ T "identity.login.authn_mode_otp_send.with" }} {{ if eq .Data.OtpMode "sms"}}{{ T "identity.login.authn_mode_otp_send.sms" }}{{ else if eq .Data.OtpMode "voice"}}{{ T "identity.login.authn_mode_otp_send.voice" }}{{ else if eq .Data.OtpMode "email"}}{{ T "identity.login.authn_mode_otp_send.email" }}{{ else }}{{ T "identity.login.authn_mode_otp_send.verification" }}{{ end }} {{ T "identity.login.authn_mode_otp_send.code" }}</h1>
      {{ if .Data.Is2FAStep }}
          <img src="{{ .Config.Assets }}/static/images/2fa-icon.svg" alt="second factor step" class="icon-2fa"/>
      {{ end }}
  </div>

  {{ if or (.Data.IsForceAuthMode) ( and (.Data.Is2FAStep) (eq .Data.Identifier ""))}}
      <div class="login-welcome-back-card">
        <img src="{{ .Config.Assets }}/static/images/person-icon.svg" alt="person icon"/>
        <div>
          <div class="login-welcome-back-card-name">
            {{ .Data.UserDisplayName }}
          </div>
        </div>
      </div>
  {{ else }}
  <div class="form-field">
    <label for="text-field-username-input" class="label-with-link">
      <span id="username-label">{{ T "identity.login.authn_mode_otp_send.email_mobile_username" }}</span>
    </label>
      {{ if .Data.Is2FAStep }}
        <input id="text-field-username-input" name="identifier" autocomplete="off" data-lpignore="true" type="hidden" value="{{ .Data.Identifier }}" disabled>
        <div class="username-div">{{ .Data.Identifier }}</div>
      {{ else }}
        <input id="text-field-username-input" name="identifier" value="{{ .Data.Identifier }}">
      {{ end }}
  </div>
  {{ end }}

  {{ template "reduce_mfa_prompts" . }}

    <div class="buttons-container-full-width flex-row-reverse">
      <button class="submit-button" type="submit" name="action" value="send_{{ if (not (eq .Data.OtpMode "" ))}}{{ .Data.OtpMode }}_{{ end }}otp" id="send-code-button">
        {{ T "identity.login.authn_mode_otp_send.continue" }}
      </button>
      {{ template "allow_skip_2fa_in_login" . }}
    </div>

  {{ if .Data.AuthnModeSwitch }}
    {{ template "authn_methods" . }}
  {{ end }}

  <input type="hidden" name="authn_mode" value="otp_send_view" id="authnView-input">

{{ end }}
