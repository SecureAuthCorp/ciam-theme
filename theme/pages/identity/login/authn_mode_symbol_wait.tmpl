{{ define "authn_symbol_wait" }}

  <div class="notification-container" id="code-sent-notification">
    <i class="material-icons">send</i>
    <span>{{ T "identity.login.authn_mode_symbol.sent" }}</span>
  </div>

  <div class="log-in-header-container">
    <h1 id="log-in-header">
      {{ T "identity.login.authn_mode_symbol.confirm" }}
    </h1>
    {{ if .Data.Is2FAStep }}
      <img src="{{ .Config.Assets }}/static/images/2fa-icon.svg" alt="second factor icon" class="icon-2fa"/>
    {{ end }}
  </div>

  {{ if .Data.IsForceAuthMode}}
    <div class="login-welcome-back-card">
      <img src="{{ .Config.Assets }}/static/images/person-icon.svg" alt="person icon"/>
      <div>
        <div class="login-welcome-back-card-name">
          {{ .Data.UserDisplayName }}
        </div>
      </div>
    </div>
  {{ else }}
    <div class="form-field">
      <label for="text-field-username-input" class="label-with-link">
        <span id="username-label">{{ T "identity.login.authn_mode_symbol.username_label" }}</span>
        {{ if not .Data.Is2FAStep }}
          <button id="not-you-button" type="submit" name="action"
                  value="change_to_symbol">{{ T "identity.login.authn_mode_symbol.change" }}</button>
        {{ end }}
      </label>
      <div class="username-div">{{ .Data.Identifier }}</div>
    </div>
  {{ end }}

  <div class="push-loader-container">
      {{ template "lottie_player" dict "Nonce" .Nonce "Assets" .Config.Assets "Src" "loader-symbol.json" }}
      <div class="push-symbol">{{ .Data.PushSymbol }}</div>
      <div class="loader-text">{{ T "identity.login.authn_mode_push.waiting_for_approval" }}</div>
  </div>

  {{ template "no_access_to_device" . }}

  {{ template "reduce_mfa_prompts" . }}

  {{ if .Data.AuthnModeSwitch }}
    {{ template "authn_methods" . }}
  {{ end }}

  <input type="checkbox" name="symbolMode" id="symbolMode" checked class="non-visible">
  <input type="hidden" name="authn_mode" value="symbol_wait" id="authnView-input">
  <input id="original-identifier-input" type="hidden" name="identifier" value="{{ .Data.Identifier }}">

  {{ template "faye_subscribe" dict "FayeURL" .Data.FayeURL "Nonce" .Nonce "FormId" "sign-in-form" "Channel" .Data.Channel }}

  <div class="non-visible" id="version" data-version="identity-pool-login"></div>
{{ end }}