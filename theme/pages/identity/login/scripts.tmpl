{{ define "identity_login_scripts" }}

<script nonce="{{.Config.Nonce}}">

  var otpLength = {{ .Data.OtpLength }};
  var totpLength = {{ .Data.TotpLength }};
  var identifier = "{{ .Data.Identifier }}";
  var isForceAuthMode = "{{.Data.IsForceAuthMode }}" === "true";

  function showWebAuthnError(message) {
    var form = document.querySelector('#sign-in-form');
    if (!form) return;

    var errorDiv = form.querySelector('.webauthn-error');
    if (errorDiv) {
      errorDiv.textContent = '';
    } else {
      errorDiv = document.createElement('div');
      errorDiv.className = 'error-container webauthn-error';
      form.insertBefore(errorDiv, form.firstChild);
    }

    var icon = document.createElement('i');
    icon.className = 'material-icons';
    icon.textContent = 'error_outline';
    errorDiv.appendChild(icon);
    errorDiv.appendChild(document.createTextNode(' ' + message));
  }

  document.addEventListener("DOMContentLoaded", onPageLoad);

  function onPageLoad() {
    var url = new URL(window.location.href);
    var preview = url.searchParams.get("preview");

    setUsernameInputEnableOnSubmit();
    initOtpInput('otp-input-container', otpLength);
    initTotpInput('totp-input-container', totpLength );

    if (preview !== 'true') {
      applyFocus();
      disableButtonsOnEmptyInputs();
      setButtonEnablementOnInput();
    }

    initWebAuthn();

    var form = document.querySelector('#sign-in-form');
    var formSubmitButton = document.querySelector('.submit-button');

    if (form && formSubmitButton) {
      form.addEventListener('keydown', function(event) {
        if (event.key === 'Enter') {
          event.preventDefault();
          formSubmitButton.click();
        }
      });
    }
  }

  function setUsernameInputEnableOnSubmit() {
    var usernameInput = document.getElementById('text-field-username-input');
    var form = document.querySelector('form');

    if (!form || !usernameInput) return;
    form.addEventListener('submit', function () {
      usernameInput.disabled = false;
    });
  }

  function applyFocus() {
    var passwordInput = document.getElementById('text-field-password-input');
    var userNameInput = document.getElementById('text-field-username-input');

    if (identifier === "" && !!userNameInput) {
      userNameInput.focus();
    } else if(!!passwordInput) {
      passwordInput.focus();
    }
  }

  function setButtonEnablementOnInput() {
    var inputNodes = ['text-field-username-input', 'text-field-password-input', 'otp-input', 'totp-input'];
    inputNodes.map(elementId => document.getElementById(elementId))
      .filter(inputNode => !!inputNode)
      .forEach(existingInputNode => {
        addInputListeners(existingInputNode, disableButtonsOnEmptyInputs);
      });
  }

  function disableButtonsOnEmptyInputs() {
    var usernameInput = document.getElementById('text-field-username-input') || document.getElementById('original-identifier-input');
    var passwordInput = document.getElementById('text-field-password-input');
    var otpInput = document.getElementById('otp-input');
    var totpInput = document.getElementById('totp-input');
    var signInButton = document.getElementById('sign-in-button');
    var webAuthnSignInButton = document.getElementById('web-authn-sign-in-button');
    var sendCodeButton = document.getElementById('send-code-button');
    var verifyButton = document.getElementById('verify-button');
    var totpVerifyButton = document.getElementById('totp-sign-in-button');

    if(usernameInput && passwordInput && signInButton) signInButton.disabled = !usernameInput.value || !passwordInput.value;
    if(usernameInput && webAuthnSignInButton) webAuthnSignInButton.disabled = !usernameInput.value;
    if(usernameInput && sendCodeButton) sendCodeButton.disabled = !usernameInput.value;
    if(usernameInput && otpInput && verifyButton) verifyButton.disabled = (!isForceAuthMode && !usernameInput.value) || !otpInput.value || otpInput.value.length < otpLength;
    if(usernameInput && totpInput && totpVerifyButton) totpVerifyButton.disabled = !usernameInput.value || !totpInput.value || totpInput.value.length < totpLength;
  }

  function initWebAuthn() {
    var form = document.querySelector('form');
    var view = {{ .Data.AuthnView }};
    var signInButton = document.getElementById('sign-in-button');
    var usernameInput = document.getElementById('text-field-username-input');
    var userIdField = document.getElementById('user-id');

    if (view === "web_authn_view") {
      form.addEventListener("submit", function (e) {
        if (e.submitter.id !== "web-authn-sign-in-button") {
          return;
        }

        e.preventDefault();
        webAuthnLogin();
      });

      var identifier = usernameInput ? usernameInput.value : "";
      var user_id = userIdField ? userIdField.value : "";
      var hasError = document.querySelector('.error-container') !== null;

      if (!hasError && (identifier !== "" || user_id !== "")) {
          webAuthnLogin();
      }
    } else if (view === "usernameless_web_authn_view") {
      form.addEventListener("submit", function (e) {
        if (e.submitter.id !== "usernameless-web-authn-sign-in-button") {
          return;
        }

        e.preventDefault();
        usernamelessWebAuthnLogin();
      });

      if (!document.querySelector('.error-container')) {
        usernamelessWebAuthnLogin();
      }
    } else {
       form.addEventListener("submit", function (e) {
        if (signInButton) {
          signInButton.disabled = true;
        }
      });
    }
  }

  function webAuthnLogin() {
    var webAuthnError = document.querySelector("#hidden-text-field-webauthn-error");
    var server_id = (new URL(document.location)).searchParams.get("server_id");
    var login_id = (new URL(document.location)).searchParams.get("login_id");
    var login_state = (new URL(document.location)).searchParams.get("login_state");
    var user_id = "";
    if (document.querySelector("#user-id") !== null) {
        user_id = document.querySelector("#user-id").value;
    }
    var identifier = "";
    if (document.querySelector("#text-field-username-input") !== null) {
        identifier = document.querySelector("#text-field-username-input").value;
    }
    var params = { server_id: server_id };
    if (login_id !== null) {
      params.login_id = login_id;
    }
    if (login_state !== null) {
      params.login_state = login_state;
    }

    webAuthnError.value = '';

    var isCredentialError = false;

    fetch(window.location.pathname + "/webauthn/options?" + new URLSearchParams(params), {
      method: "POST",
      body: JSON.stringify({
        identifier: identifier,
        user_id: user_id,
      }),
    })
    .then(function (response) {
      if (!response.ok) {
        return response.json().then(function (body) {
          throw new Error(body.error || "Server error: " + response.status);
        });
      }
      return response.json();
    })
    .then((credentialRequestOptions) => {
      credentialRequestOptions.publicKey.challenge = bufferDecode(credentialRequestOptions.publicKey.challenge);
      credentialRequestOptions.publicKey.allowCredentials.forEach(function (listItem) {
        listItem.id = bufferDecode(listItem.id);
      });

      return navigator.credentials.get({
        publicKey: credentialRequestOptions.publicKey
      });
    })
    .then((assertion) => {
      let authData = assertion.response.authenticatorData;
      let clientDataJSON = assertion.response.clientDataJSON;
      let rawId = assertion.rawId;
      let sig = assertion.response.signature;
      let userHandle = assertion.response.userHandle;

      return fetch(window.location.pathname + "/webauthn/finish?" + new URLSearchParams(params), {
        method: "POST",
        body: JSON.stringify({
          id: assertion.id,
          rawId: bufferEncode(rawId),
          type: assertion.type,
          response: {
            authenticatorData: bufferEncode(authData),
            clientDataJSON: bufferEncode(clientDataJSON),
            signature: bufferEncode(sig),
            userHandle: bufferEncode(userHandle),
          },
        }),
      });

    })
    .catch((error) => {
      webAuthnError.value = String(error);
      if (error instanceof DOMException) {
        isCredentialError = true;
      }
    })
    .finally(() => {
      if (webAuthnError.value.startsWith("NotAllowedError:") || webAuthnError.value.startsWith("AbortError:")) {
        webAuthnError.value = '';
      } else if (isCredentialError) {
        showWebAuthnError("Passkey authentication failed. Try a different method or contact your administrator.");
        webAuthnError.value = '';
      } else {
        document.querySelector('form').submit();
      }
    });
  }

  function usernamelessWebAuthnLogin() {
    var webAuthnError = document.querySelector("#hidden-text-field-webauthn-error");
    var server_id = (new URL(document.location)).searchParams.get("server_id");
    var login_id = (new URL(document.location)).searchParams.get("login_id");
    var login_state = (new URL(document.location)).searchParams.get("login_state");
    var params = { server_id: server_id };
    if (login_id !== null) {
      params.login_id = login_id;
    }
    if (login_state !== null) {
      params.login_state = login_state;
    }

    webAuthnError.value = '';

    var isCredentialError = false;

    fetch(window.location.pathname + "/usernameless-webauthn/options?" + new URLSearchParams(params), {
      method: "POST",
    })
    .then(function (response) {
      if (!response.ok) {
        return response.json().then(function (body) {
          throw new Error(body.error || "Server error: " + response.status);
        });
      }
      return response.json();
    })
    .then((credentialRequestOptions) => {
      credentialRequestOptions.publicKey.challenge = bufferDecode(credentialRequestOptions.publicKey.challenge);
      if (credentialRequestOptions.publicKey.allowCredentials) {
        credentialRequestOptions.publicKey.allowCredentials.forEach(function (listItem) {
          listItem.id = bufferDecode(listItem.id);
        });
      }

      return navigator.credentials.get({
        publicKey: credentialRequestOptions.publicKey
      });
    })
    .then((assertion) => {
      let authData = assertion.response.authenticatorData;
      let clientDataJSON = assertion.response.clientDataJSON;
      let rawId = assertion.rawId;
      let sig = assertion.response.signature;
      let userHandle = assertion.response.userHandle;

      return fetch(window.location.pathname + "/usernameless-webauthn/finish?" + new URLSearchParams(params), {
        method: "POST",
        body: JSON.stringify({
          id: assertion.id,
          rawId: bufferEncode(rawId),
          type: assertion.type,
          response: {
            authenticatorData: bufferEncode(authData),
            clientDataJSON: bufferEncode(clientDataJSON),
            signature: bufferEncode(sig),
            userHandle: bufferEncode(userHandle),
          },
        }),
      });
    })
    .catch((error) => {
      webAuthnError.value = String(error);
      if (error instanceof DOMException) {
        isCredentialError = true;
      }
    })
    .finally(() => {
      if (webAuthnError.value.startsWith("NotAllowedError:") || webAuthnError.value.startsWith("AbortError:")) {
        webAuthnError.value = '';
      } else if (isCredentialError) {
        showWebAuthnError("Passkey authentication failed. Try a different method or contact your administrator.");
        webAuthnError.value = '';
      } else {
        document.querySelector('form').submit();
      }
    });
  }

  function bufferEncode(value) {
    return btoa(String.fromCharCode.apply(null, new Uint8Array(value)))
      .replace(/\+/g, "-")
      .replace(/\//g, "_")
      .replace(/=/g, "");
  }

  function bufferDecode(value) {
    return Uint8Array.from(atob(value.replace(/-/g, '+').replace(/_/g, '/')), c => c.charCodeAt(0));
  }

</script>

{{ end }}