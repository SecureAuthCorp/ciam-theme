{{ define "authn_symbol_send" }}
  <div class="log-in-header-container">
      <h1 id="log-in-header">
        {{ T "identity.login.authn_mode_symbol.log_in" }}
      </h1>
      {{ if .Data.Is2FAStep }}
          <img src="{{ .Config.Assets }}/static/images/2fa-icon.svg" alt="second factor step" class="icon-2fa"/>
      {{ end }}
  </div>

  {{ if .Data.IsForceAuthMode}}
      <div class="login-welcome-back-card">
        <img src="{{ .Config.Assets }}/static/images/person-icon.svg" alt="person icon"/>
        <div>
          <div class="login-welcome-back-card-name">
            {{ .Data.UserDisplayName }}
          </div>
        </div>
      </div>
  {{ else }}
  <div class="form-field">
    <label for="text-field-username-input" class="label-with-link">
      <span id="username-label">{{ T "identity.login.authn_mode_symbol.username_label" }}</span>
    </label>
      {{ if .Data.Is2FAStep }}
        <input id="text-field-username-input" name="identifier" autocomplete="off" data-lpignore="true" type="hidden" value="{{ .Data.Identifier }}" disabled>
        <div class="username-div">{{ .Data.Identifier }}</div>
      {{ else }}
        <input id="text-field-username-input" name="identifier" value="{{ .Data.Identifier }}">
      {{ end }}
  </div>
  {{ end }}

  {{ if .Data.IsSelfResetCredentialsAllowed }}
      <div class="push-no-access-container">
          <span class="no-access-text">{{ T "identity.login.authn_mode_push.no_access_to_device" }}</span>
          <a href="{{ .Data.PairNewDevicePath }}" id="no-access-to-device" class="input-above-link" tabindex="0">{{ T "identity.login.authn_mode_push.pair_new_device" }}</a>
      </div>
  {{ end }}

  {{ template "reduce_mfa_prompts" . }}

    <div class="buttons-container-full-width flex-row-reverse">
      <button class="submit-button" type="submit" name="action" value="send_symbol" id="send-code-button">
        {{ T "identity.login.authn_mode_symbol.continue" }}
      </button>
      {{ template "allow_skip_2fa_in_login" . }}
    </div>

  {{ if .Data.AuthnModeSwitch }}
    {{ template "authn_methods" . }}
  {{ end }}

  <input type="hidden" name="authn_mode" value="symbol_send_view" id="authnView-input">

{{ end }}