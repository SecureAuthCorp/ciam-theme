{{ define "authn_totp" }}

  <div class="log-in-header-container">
      <h1 id="log-in-header">{{ if .Data.IsForceAuthMode}}{{ T "identity.login.authn_mode_totp.confirm" }}{{ else }}{{ T "identity.login.authn_mode_totp.log_in" }}{{ end }} {{ T "identity.login.authn_mode_totp.with_authenticator" }}</h1>
      {{ if .Data.Is2FAStep }}
          <img src="{{ .Config.Assets }}/static/images/2fa-icon.svg" alt="second factor icon" class="icon-2fa"/>
      {{ end }}
  </div>

  {{ if .Data.IsForceAuthMode}}
      <div class="login-welcome-back-card">
        <img src="{{ .Config.Assets }}/static/images/person-icon.svg" alt="person icon"/>
        <div>
          <div class="login-welcome-back-card-name">
            {{ .Data.UserDisplayName }}
          </div>
        </div>
      </div>
  {{ else }}
      <div class="form-field">
        <label for="text-field-username-input" class="label-with-link">
          <span id="username-label">{{ T "identity.login.authn_mode_totp.username_label" }}</span>
        </label>
        {{ if .Data.Is2FAStep }}
          <input id="text-field-username-input" name="identifier" autocomplete="off" data-lpignore="true" type="hidden" value="{{ .Data.Identifier }}" disabled>
          <div class="username-div">{{ .Data.Identifier }}</div>
        {{ else }}
          <input id="text-field-username-input" name="identifier" value="{{ .Data.Identifier }}">
        {{ end }}
      </div>
  {{ end }}

   <div class="form-field totp-container" id="totp-container">
       <label for="text-field-totp-input">
           <span id="totp-label">{{ T "identity.login.authn_mode_totp.totp_label" }}</span>
           {{ if .Data.IsSelfResetCredentialsAllowed }}
               <a href="{{ .Data.ResetTOTPPath }}" id="forgot-totp" class="input-above-link" tabindex="0">{{ T "identity.login.authn_mode_totp.lost_authenticator" }}</a>
           {{ end }}
       </label>

       <div id="totp-input-container" class="form-field otp-input-container">
            <input type="hidden" name="totp" value="" id="totp-input">
       </div>
   </div>

  {{ template "reduce_mfa_prompts" . }}

    <div class="buttons-container-full-width flex-row-reverse">
      <button class="submit-button" type="submit" id="totp-sign-in-button">
          {{ T "identity.login.authn_mode_totp.continue" }}
      </button>
      {{ template "allow_skip_2fa_in_login" . }}
    </div>

  {{ if .Data.AuthnModeSwitch }}
    {{ template "authn_methods" . }}
  {{ end }}

  <input type="checkbox" name="totpMode" id="totpMode" checked class="non-visible">
  <input type="hidden" name="authn_mode" value="totp_view" id="authnView-input">

  <div class="non-visible" id="version" data-version="identity-pool-login"></div>
{{ end }}
