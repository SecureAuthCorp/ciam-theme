{{ define "authn_push_wait" }}

  <div class="notification-container" id="code-sent-notification">
    <i class="material-icons">send</i>
    <span>{{ T "identity.login.authn_mode_push.sent" }}</span>
  </div>

  <div class="log-in-header-container">
      <h1 id="log-in-header">
        {{ T "identity.login.authn_mode_push.confirm" }}
      </h1>
      {{ if .Data.Is2FAStep }}
          <img src="{{ .Config.Assets }}/static/images/2fa-icon.svg" alt="second factor icon" class="icon-2fa"/>
      {{ end }}
  </div>

  {{ if .Data.IsForceAuthMode}}
      <div class="login-welcome-back-card">
          <img src="{{ .Config.Assets }}/static/images/person-icon.svg" alt="person icon"/>
          <div>
          <div class="login-welcome-back-card-name">
              {{ .Data.UserDisplayName }}
          </div>
          </div>
      </div>
  {{ else }}
  <div class="form-field">
      <label for="text-field-username-input" class="label-with-link">
          <span id="username-label">{{ T "identity.login.authn_mode_push.username_label" }}</span>
          {{ if not .Data.Is2FAStep }}
              <button id="not-you-button" type="submit" name="action" value="change_to_push">{{ T "identity.login.authn_mode_push.change" }}</button>
          {{ end }}
      </label>
      <div class="username-div">{{ .Data.Identifier }}</div>
  </div>
  {{ end }}

  <div style="display: flex; align-items: center; justify-content: center; margin-bottom: 10px;">
    <span class="loader"></span>
  </div>

  {{ template "reduce_mfa_prompts" . }}

  {{ if .Data.AuthnModeSwitch }}
    {{ template "authn_methods" . }}
  {{ end }}

  <input type="checkbox" name="pushMode" id="pushMode" checked class="non-visible">
  <input type="hidden" name="authn_mode" value="push_wait" id="authnView-input">
  <input id="original-identifier-input" type="hidden" name="identifier" value="{{ .Data.Identifier }}">

  <script src="{{ .Data.FayeURL }}/faye/faye.js"></script>
  <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.3.1/jquery.min.js"></script>

  <script type="text/JavaScript">
    $(function() {
      var faye = new Faye.Client("{{ .Data.FayeURL }}/faye");
      var form = document.getElementById("sign-in-form");
      faye.subscribe("/messages/{{ .Data.Channel }}", function (data) {
        form.submit();
      });
    });
  </script>

  <div class="non-visible" id="version" data-version="identity-pool-login"></div>
{{ end }}