{{ define "setup_with_device" }}

  <div class="setup-credential-header-container">
    <div>
        <h1 class="no-bottom-margin">{{ T "identity.activate.pair_device.set_up" }}</h1>
        <div class="header-bottom-info">{{ T "identity.activate.pair_device.install_app_info" }}</div>
    </div>
    {{ if .Data.Is2FAStep }}
      <img src="{{ .Config.Assets }}/static/images/2fa-icon.svg" alt="second factor step" class="icon-2fa"/>
    {{ end }}
  </div>

  <div class="form-field">
    <label for="text-field-username-input">
      {{ T "identity.activate.pair_device.email_or_mobile" }}
    </label>
    <input id="text-field-username-input" name="username" autocomplete="off" data-lpignore="true" type="hidden"
           value="{{ .Data.Identifier }}" disabled>
    <div class="username-div">{{ .Data.Identifier }}</div>
  </div>

  <input type="hidden" name="pair_device" value="done" id="pair_device" form="sign-up-form">

  {{ if .Data.DeviceAlreadyPaired}}

    <label class="device-already-paired-label">
      <span id="device-already-paired-label"> {{ T "identity.activate.pair_device.device_already_paired" }} </span>
    </label>

    <div class="form-field">
      <button class="submit-button" type="submit" id="sign-up-button">
        <span>{{ T "identity.activate.pair_device.continue" }}</span>
      </button>
    </div>

  {{ else }}

      {{ if .Data.DevicePairingInvitationQR }}
          {{ template "qr_code_scan_device_pairing" . }}
      {{ else }}
          <div class="push-loader-container">
              <span class="loader"></span>
          </div>
      {{ end }}

    {{ if .Data.AllowToSkip }}
        <div class="buttons-container-full-width flex-row-reverse extra-top-margin">
          {{ template "allow_skip_2fa_in_activate" . }}
        </div>
    {{ end }}

    {{ template "faye_subscribe" dict "FayeURL" .Data.FayeURL "Nonce" .Nonce "FormId" "sign-up-form" "Channel" .Data.DevicePairingInvitationChannel }}

  {{ end }}

  {{ if .Data.ModeSwitch }}
    {{ template "activation_methods" . }}
  {{ end }}

{{ end }}