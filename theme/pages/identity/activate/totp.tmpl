{{ define "setup_with_totp" }}

{{ template "identity_activate_disable_submit_empty_totp_script" . }}

  <div class="setup-credential-header-container">
  <h1>{{ T "identity.activate.totp.set_up_authenticator_app" }}</h1>
    {{ if .Data.Is2FAStep }}
        <img src="{{ .Config.Assets }}/static/images/2fa-icon.svg" alt="second factor step" class="icon-2fa"/>
    {{ end }}
  </div>

  <div class="form-field">
    <label for="text-field-username-input">
      {{ T "identity.activate.totp.email_or_mobile" }}
    </label>
    <input id="text-field-username-input" name="username" autocomplete="off" data-lpignore="true" type="hidden" value="{{ .Data.Identifier }}" disabled>
    <div class="username-div">{{ .Data.Identifier }}</div>
  </div>

  <label for="text-field-totp-input">
    <span id="authenticator-label">{{ T "identity.activate.totp.scan_qr_code" }}</span>
  </label>
  <div class="form-field totp-container with-setup" id="totp-container">
      <div class="totp-qrcode-container">
          <div id="totp-qrcode" data-qrdata="{{.Data.TOTPRegistrationURL}}"></div>
          <div class="totp-setup-key-container">
              <a id="setup-key-toggle" href="" onclick="toggleSetupKey(event, {{ T "identity.activate.totp.cant_scan_qr_code" }}, {{ T "identity.activate.totp.hide_qr_code" }})">{{ T "identity.activate.totp.cant_scan_qr_code" }}</a>
              <span id="setup-key"></span>
          </div>
      </div>
      <div class="setup-key-block">
          <span id="setup-key"></span>
          <a href="" onclick="copySetupKey(event)" aria-label="{{ T "identity.activate.totp.copy_setup_key" }}">
              <i class="material-icons">content_copy</i>
          </a>
          <span id="copied-confirmation"></span>
      </div>

      <label for="text-field-totp-input">
        <span id="totp-label">{{ T "identity.activate.totp.enter_generated_code" }}</span>
      </label>

      <div id="totp-input-container" class="form-field otp-input-container">
          <input type="hidden" name="totp" value="" id="totp-input" form="sign-up-form">
      </div>
  </div>

  <div class="buttons-container-full-width flex-row-reverse extra-top-margin">
    <button class="submit-button" type="submit" id="sign-up-button">
      <span>{{ T "identity.activate.totp.continue" }}</span>
      <div class="non-visible">{{ template "loader" . }}</div>
    </button>
    {{ template "allow_skip_2fa_in_activate" . }}
  </div>

  {{ if .Data.ModeSwitch }}
    {{ template "activation_methods" . }}
  {{ end }}

{{ end }}
