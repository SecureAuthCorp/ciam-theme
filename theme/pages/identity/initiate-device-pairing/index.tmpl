{{ template "base" . }}

{{ define "title" }}{{ T "identity.initiate_device_pairing.title" }}{{ end }}

{{ define "content" }}

  {{ template "identity_initiate_device_pairing_scripts" . }}

  <div class="header-container">
    {{ template "header" .Config }}
  </div>

  <div class="card">
    <div class="content" id="main-content">

      <form action="?login_id={{ .Data.SessionID }}&user_id={{ .Data.UserID}}&login_state={{ .Data.SessionState }}&identifier={{ .Data.Identifier }}&code={{ .Data.Code }}&server_id={{ .Data.ServerID }}&mode={{ .Data.Mode }}&view={{ .Data.DeviceAuthnView }}" method="post">

        <h1>{{ T "identity.initiate_device_pairing.initiate" }}</h1>

        {{ if not .Data.Code }}
          <div class="form-field extra-top-margin otp-container" id="otp-container">
            <div id="otp-input-container" class="form-field otp-input-container">
              <input type="hidden" name="otp" value="" id="otp-input">
            </div>
            <div class="footer-with-link">
              {{ T "identity.initiate_device_pairing.still_didnt_receive" }}
              <a href="{{ .Data.ResendPath }}">{{ T "identity.initiate_device_pairing.resend_code" }}</a>
            </div>
          </div>
        {{ end }}

        {{ range .Data.FormError.Errors }}
          {{ template "error_message" . }}
        {{ end }}

      <div class="buttons-container-full-width flex-row-reverse no-margin-bottom extra-top-margin">
        <button class="submit-button" type="submit" id="sign-in">{{ T "identity.initiate_device_pairing.continue" }}</button>
        {{ if not .Data.SetWithoutAuthentication }}
          <a href="{{ .Data.RestartResetCredentialPath }}" class="text-button-link">
            {{ T "identity.initiate_device_pairing.back" }}
          </a>
        {{ end }}
      </div>
      </form>
    </div>
  </div>

  {{ template "footer" . }}
{{ end }}
