{{ template "base" . }}

{{ define "title" }} {{ T "identity.activation_completed.user_activated" }} {{ end }}

{{ define "content" }}

  <div class="header-container">
    {{ template "header" .Config }}
  </div>

  <div class="card">
    <div class="content" id="main-content">
      {{ if .Data.UserAlreadyActive }}
        <h1>{{ T "identity.activation_completed.already_active" }}</h1>
        {{ if .Data.LoginPath }}
          <div class="header-info">{{ T "identity.activation_completed.click_below" }}</div>
        {{ end }}
      {{ else }}
        <h1>{{ T "identity.activation_completed.success" }}!</h1>
        <div class="header-info">{{ T "identity.activation_completed.info" }}</div>
      {{ end }}

      {{ if .Data.LoginPath }}
        <a href="{{ .Data.LoginPath }}">
          <button class="submit-button" id="sign-in">{{ T "identity.activation_completed.sign_in" }}</button>
        </a>
      {{ end }}
    </div>
  </div>

  {{ template "footer" . }}
{{ end }}
