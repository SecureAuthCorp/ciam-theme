{{ template "base" . }}

{{ define "title" }}{{ T "identity.reset_web_authn.title" }}{{ end }}

{{ define "content" }}
  {{ template "submit_button_disabling_script" . }}
{{ template "identity_reset_passkey_disable_submit_script" . }}

  <div class="header-container">
    {{ template "header" .Config }}
  </div>

  <div class="card">
    <div class="content" id="main-content">

      <form action="?login_id={{ .Data.SessionID }}&user_id={{ .Data.UserID}}&login_state={{ .Data.SessionState }}&server_id={{ .Data.ServerID }}&mode={{ .Data.Mode }}" method="post">

        <h1>{{ T "identity.reset_web_authn.enroll_new_passkey" }}</h1>

        <div class="form-field">
          <label for="text-field-identifier-input">
            {{ T "identity.reset_web_authn.email_or_mobile" }}
          </label>
          <input id="text-field-identifier-input" name="identifier" value="">
        </div>

        {{ if and .Data.CaptchaSiteKey (not .Data.TurnstileSiteKey) }}
          <div class="recaptcha-container">
            <div class="g-recaptcha"
              data-sitekey="{{ .Data.CaptchaSiteKey }}"
              data-callback="enableSubmit"
              data-expired-callback="disableSubmit"
              data-error-callback="disableSubmit"
            ></div>
          </div>
        {{ end }}

        {{ if .Data.TurnstileSiteKey }}
          {{ template "turnstile" . }}
        {{ end }}

        {{ range .Data.FormError.Errors }}
          {{ template "error_message" . }}
        {{ end }}

        <div class="buttons-container-full-width flex-row-reverse no-margin-bottom extra-top-margin">
          <button id="submit-next" class="submit-button" type="submit" {{ if .Data.CaptchaSiteKey }} disabled {{ end }} >
            {{ T "identity.reset_web_authn.next" }}
          </button>
          {{ if not .Data.ResetWithoutAuthentication }}
            <a href="{{ .Data.LoginPath }}" class="text-button-link">
              {{ T "identity.reset_web_authn.back" }}
            </a>
          {{ end }}
        </div>
      </form>
    </div>
  </div>

  {{ template "footer" . }}
{{ end }}
