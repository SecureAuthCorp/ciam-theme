{{ template "base" . }}

{{ define "title" }} Set up authenticator app {{ end }}

{{ define "content" }}

  {{ template "identity_set_totp_scripts" . }}

  <div class="header-container">
    {{ template "header" .Config }}
  </div>

  <div class="card">
    <div class="content" id="main-content">

      <form action="?login_id={{ .Data.SessionID }}&user_id={{ .Data.UserID}}&login_state={{ .Data.SessionState }}&identifier={{ .Data.Identifier }}&code={{ .Data.Code }}&server_id={{ .Data.ServerID }}&mode={{ .Data.Mode }}" method="post">
        {{ .Data.CsrfField }}

        <h1>Set up authenticator app</h1>

        <label for="text-field-totp-input">
          <span id="authenticator-label">Scan QR code or use setup key with your Authenticator Application</span>
        </label>
        <div class="form-field totp-container with-setup" id="totp-container">
          <div class="totp-qrcode-container">
              <div id="totp-qrcode" data-qrdata="{{.Data.TOTPRegistrationURL}}"></div>
              <div class="totp-setup-key-container">
                  <a id="setup-key-toggle" href="" onclick="toggleSetupKey(event)">Can’t scan QR?</a>
              </div>
          </div>
          <div class="setup-key-block">
              <span id="setup-key"></span>
              <a href="" onclick="copySetupKey(event)" aria-label="Copy setup key">
                  <i class="material-icons">content_copy</i>
              </a>
              <span id="copied-confirmation"></span>
          </div>

          <label for="text-field-totp-input">
              <span id="totp-label">Enter generated code from the application</span>
          </label>

          <div id="totp-input-container" class="form-field otp-input-container">
              <input type="hidden" name="totp" value="" id="totp-input">
          </div>

          {{ range .Data.FormError.Fields.totp }}
            {{ template "error_message" . }}
          {{ end }}
        </div>

        {{ if not .Data.Code }}
          <div class="form-field extra-top-margin otp-container" id="otp-container">
            <label for="text-field-otp-input" class="text-align-center">
              <span id="otp-label">Provide verification code you received</span>
            </label>
            <div id="otp-input-container" class="form-field otp-input-container">
              <input type="hidden" name="otp" value="" id="otp-input">
            </div>
            <div class="footer-with-link">
              Still didn't receive?
              <a href="{{ .Data.ResendPath }}">Resend code</a>
            </div>
          </div>
        {{ end }}

        {{ range .Data.FormError.Errors }}
          {{ template "error_message" . }}
        {{ end }}

      <div class="buttons-container-full-width flex-row-reverse no-margin-bottom extra-top-margin">
        <button class="submit-button" type="submit" id="sign-in">Continue</button>
        {{ if not .Data.SetWithoutAuthentication }}
          <a href="{{ .Data.RestartResetCredentialPath }}" class="text-button-link">
            Back
          </a>
        {{ end }}
      </div>
      </form>
    </div>
  </div>

  {{ template "footer" . }}
{{ end }}
