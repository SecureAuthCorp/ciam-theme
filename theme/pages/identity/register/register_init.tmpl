{{ define "register_init" }}

{{ template "identity_register_ux_improved_scripts" . }}

<div class="steps-container">{{ T "identity.register.register_init.step" }} <b>1</b> {{ T "identity.register.register_init.of" }} <b>3</b></div>
<h1 class="no-bottom-margin">{{ T "identity.register.register_init.register_user_account" }}</h1>

{{ if not .Data.RegistrationWithoutAuthentication }}
  <div class="header-bottom-info">{{ T "identity.register.register_init.already_have_account" }} <a href="{{ .Data.LoginPath }}">{{ T "identity.register.register_init.sign_in" }}</a></div>
{{ end }}

{{ template "form" . }}

<button id="submit-next" class="submit-button" type="submit" name="action" value="change_to_credential_entry" form="sign-up-form">
  {{ T "identity.register.register_init.continue" }}
</button>

<input id="from-view-input" name="from-view" type="text" value="user" form="sign-up-form" hidden>

{{ range .Data.FormError.Errors }}
  {{ template "error_message" . }}
{{ end }}

<!-- FIXME: disable submit button on empty fields -->

{{ end }}