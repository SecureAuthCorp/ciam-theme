{{ define "register_with_totp" }}

    {{ template "identity_register_ux_improved_scripts" . }}
    {{ template "submit_button_disabling_script" . }}

    <div class="steps-container">STEP <b>2</b> OF <b>3</b></div>

    <div class="setup-credential-header-container">
        <h1>Set up authenticator app</h1>
        {{ if .Data.Is2FAStep }}
            <img src="{{ .Config.Assets }}/static/images/2fa-icon.svg" alt="second factor step" class="icon-2fa"/>
        {{ end }}
    </div>

    <input id="from-view-input" name="from-view" type="text" value="totp" form="sign-up-form" hidden>

    <div class="form-field">
        <label for="entered-identifier">
            Email | Mobile
        </label>
        <input id="entered-identifier" name="notused" autocomplete="off" data-lpignore="true" type="hidden" value="{{ .Data.EnteredIdentifier }}" disabled>
        <div class="username-div">{{ .Data.EnteredIdentifier }}</div>
    </div>

    <div class="form-field totp-container" id="totp-container">
        <label for="text-field-totp-input">
            <span id="authenticator-label">Scan QR code or use setup key with your authenticator app</span>
        </label>

        <div class="totp-qrcode-container">
            <div id="totp-qrcode" data-qrdata="{{.Data.TOTPRegistrationURL}}"></div>
            <div class="totp-setup-key-container">
                <a id="setup-key-toggle" href="" onclick="toggleSetupKey(event)">View setup key</a>
                <span id="setup-key"></span>
            </div>
        </div>

        <label for="text-field-totp-input">
            <span id="totp-label">Enter generated code from the app</span>
        </label>

        <div id="totp-input-container" class="form-field otp-input-container">
            <input type="hidden" name="totp" value="" id="totp-input" form="sign-up-form">
        </div>

        {{ range .Data.FormError.Errors }}
            {{ template "error_message" . }}
        {{ end }}
    </div>

    {{ template "form" . }}

    <div class="buttons-container-full-width extra-top-margin flex-row-reverse">
        <button class="submit-button" type="submit" id="submit-next" name="action" value="submit" form="sign-up-form" {{ if .Data.CaptchaSiteKey }}disabled{{end}}>
            <span>Continue</span>
            <div class="non-visible">{{ template "loader" . }}</div>
        </button>

        <button type="submit" name="action" value="change_to_user" class="text-button" form="sign-up-form">
            Back
        </button>
    </div>
    {{ template "allow_skip_2fa_in_register" . }}

    {{ if .Data.AuthnModeSwitch }}
        {{ template "register_methods" . }}
    {{ end }}

{{ end }}
