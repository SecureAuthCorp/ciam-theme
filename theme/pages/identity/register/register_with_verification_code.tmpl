{{ define "register_with_verification_code" }}

{{ template "identity_register_ux_improved_scripts" . }}
{{ template "submit_button_disabling_script" . }}

<div class="steps-container">{{ T "identity.register.register_with_verification_code.step" }} <b>2</b> {{ T "identity.register.register_with_verification_code.of" }} <b>3</b></div>

<div class="setup-credential-header-container">
    <h1>Use {{ if eq .Data.OtpMode "email" }}email{{ else if eq .Data.OtpMode "sms" }}mobile{{ else if eq .Data.OtpMode "voice" }}mobile{{ else }}{{ .Data.EnteredIdentifierType }}{{ end }} for sign-in</h1>
    {{ if .Data.Is2FAStep }}
        <img src="{{ .Config.Assets }}/static/images/2fa-icon.svg" alt="second factor step" class="icon-2fa"/>
    {{ end }}
</div>

<input id="from-view-input" name="from-view" type="text" value="{{ if eq .Data.OtpMode "email" }}email_{{ else if eq .Data.OtpMode "sms" }}sms_{{ else if eq .Data.OtpMode "voice" }}voice_{{ end }}otp" form="sign-up-form" hidden>

<div class="form-field">
  <label for="entered-identifier">
      {{ if eq .Data.OtpMode "email" }}
          {{ T "identity.register.register_with_verification_code.email" }}
      {{ else if eq .Data.OtpMode "sms" }}
          {{ T "identity.register.register_with_verification_code.mobile" }}
      {{ else if eq .Data.OtpMode "voice" }}
          {{ T "identity.register.register_with_verification_code.mobile" }}
      {{ else }}
          {{ T "identity.register.register_with_verification_code.email_or_mobile" }}
      {{ end }}
  </label>
    {{ if or (eq .Data.OtpMode "") (eq .Data.OtpMode .Data.EnteredIdentifierType) (and (eq .Data.EnteredIdentifierType "mobile") (or (eq .Data.OtpMode "sms") (eq .Data.OtpMode "voice"))) }}
      <input id="entered-identifier" name="notused" autocomplete="off" data-lpignore="true" type="hidden" value="{{ .Data.EnteredIdentifier }}" disabled>
      <div class="username-div">{{ .Data.EnteredIdentifier }}</div>
    {{ else if eq .Data.OtpMode "email" }}
      <input id="text-field-username-input" name="new_address" data-lpignore="true" form="sign-up-form">
      <div id="address-field-error" class="non-visible"></div>
    {{ else if eq .Data.OtpMode "sms" }}
      <input id="text-field-username-input" name="new_address" data-lpignore="true" form="sign-up-form">
      <div id="address-field-error" class="non-visible"></div>
    {{ else if eq .Data.OtpMode "voice" }}
      <input id="text-field-username-input" name="new_address" data-lpignore="true" form="sign-up-form">
      <div id="address-field-error" class="non-visible"></div>
    {{ end }}

    {{ range .Data.FormError.Errors }}
        {{ template "error_message" . }}
    {{ end }}
</div>

{{ template "form" . }}

<div class="buttons-container-full-width extra-top-margin flex-row-reverse">
  <button class="submit-button" type="submit" id="submit-next" name="action" value="submit" form="sign-up-form" {{ if .Data.CaptchaSiteKey }}disabled{{end}}>
    <span>{{ T "identity.register.register_with_verification_code.continue" }}</span>
    <div class="non-visible">{{ template "loader" . }}</div>
  </button>

  <button type="submit" name="action" value="change_to_user" class="text-button" form="sign-up-form">
    {{ T "identity.register.register_with_verification_code.back" }}
  </button>
</div>

{{ template "allow_skip_2fa_in_register" . }}

{{ if .Data.AuthnModeSwitch }}
    {{ template "register_methods" . }}
{{ end }}

{{ end }}
